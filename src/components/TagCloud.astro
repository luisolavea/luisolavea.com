---
type Props = {
	tags: string[];
};

const { tags } = Astro.props;
---

<div class="tag-cloud">
	{
		tags.map((tag) => (
			<span class="tag">{tag}</span>
		))
	}
</div>

<style>
	.tag-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 1rem 0;
	}
	.tag {
		display: inline-block;
		padding: 0.25em 0.75em;
		font-size: 0.875rem;
		color: rgb(var(--gray-dark));
		background: rgba(var(--gray-light), 0.5);
		border-radius: 999px;
	}
</style>
