---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Filtrar posts por categoría
const articlePosts = allPosts.filter(post => post.data.category !== 'videos');
const videoPosts = allPosts.filter(post => post.data.category === 'videos');

// Últimos 9 artículos para el home
const latestArticles = articlePosts.slice(0, 9);

// Últimas 3 recomendaciones (videos)
const latestVideos = videoPosts.slice(0, 3);

// Categorías activas (excluyendo videos)
const categories = [
	{ slug: 'domotica', label: '🏠 Domótica' },
	{ slug: 'energia-solar', label: '☀️ Energía Solar' },
	{ slug: 'tecnologia', label: '💻 Tecnología' },
	{ slug: 'vida', label: '🌱 Vida' },
];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2em 1em;
			}
			.section-title {
				font-size: 1.5rem;
				margin: 2rem 0 1rem 0;
				color: rgb(var(--black));
				border-bottom: 2px solid rgb(var(--accent));
				padding-bottom: 0.5rem;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			.category {
				display: inline-block;
				margin-top: 0.5rem;
				font-size: 0.875rem;
				color: rgb(var(--accent));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			
			/* Estilos para sección de videos */
			.video-section {
				margin-top: 3rem;
				padding-top: 2rem;
				border-top: 1px solid rgba(var(--gray), 0.2);
			}
			.video-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.5rem;
			}
			.video-card {
				background: rgba(var(--gray), 0.05);
				border-radius: 12px;
				padding: 1rem;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			.video-card:hover {
				transform: translateY(-4px);
				box-shadow: var(--box-shadow);
			}
			.video-card a {
				text-decoration: none;
				color: inherit;
			}
			.video-card h5 {
				margin: 0.75rem 0 0.25rem 0;
				font-size: 1rem;
				color: rgb(var(--black));
			}
			.video-card .date {
				font-size: 0.8rem;
			}
			.video-placeholder {
				width: 100%;
				height: 160px;
				background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
				border-radius: 8px;
				display: flex;
				align-items: center;
				justify-content: center;
				color: white;
				font-size: 2rem;
			}
			
			/* Link ver más videos */
			.see-more {
				text-align: center;
				margin-top: 1.5rem;
			}
			.see-more a {
				display: inline-block;
				padding: 0.75rem 1.5rem;
				background: rgb(var(--accent));
				color: white;
				text-decoration: none;
				border-radius: 4px;
				font-weight: 500;
				transition: background 0.2s ease;
			}
			.see-more a:hover {
				background: rgb(var(--accent-dark));
			}
			
			/* Sección de categorías */
			.categories-section {
				margin-top: 3rem;
				padding-top: 2rem;
				border-top: 1px solid rgba(var(--gray), 0.2);
			}
			.category-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1rem;
				margin-top: 1rem;
			}
			.category-card {
				background: rgba(var(--gray), 0.05);
				border-radius: 12px;
				padding: 1.5rem;
				text-align: center;
				transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
				text-decoration: none;
				color: rgb(var(--black));
				font-weight: 500;
			}
			.category-card:hover {
				transform: translateY(-4px);
				box-shadow: var(--box-shadow);
				background: rgba(var(--accent), 0.1);
			}
			
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
				.video-grid {
					grid-template-columns: 1fr;
				}
				.category-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- Sección de Artículos -->
			<section>
				<h3 class="section-title">Últimos artículos</h3>
				<ul>
					{
						latestArticles.map((post) => (
							<li>
								<a href={`/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									{post.data.category && (
										<span class="category">{post.data.category}</span>
									)}
								</a>
							</li>
						))
						}
					</ul>
				</section>
				
			<!-- Sección Explorar por Tema -->
			<section class="categories-section">
				<h3 class="section-title">Explorar por tema</h3>
				<div class="category-grid">
					{categories.map((cat) => (
						<a href={`/category/${cat.slug}`} class="category-card">
							{cat.label}
						</a>
					))}
				</div>
			</section>
			
			<!-- Sección de Videos Recomendados -->
			{latestVideos.length > 0 && (
				<section class="video-section">
					<h3 class="section-title">Últimas recomendaciones</h3>
					<div class="video-grid">
						{latestVideos.map((video) => (
							<div class="video-card">
								<a href={`/${video.id}/`}>
									<div class="video-placeholder">▶</div>
									<h5>{video.data.title}</h5>
									<p class="date">
										<FormattedDate date={video.data.pubDate} />
									</p>
								</a>
							</div>
						))}
					</div>
					<div class="see-more">
						<a href="/videos">Ver más videos →</a>
					</div>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>