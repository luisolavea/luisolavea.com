---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Filtrar solo videos
const videoPosts = allPosts.filter(post => post.data.category === 'videos');

const pageTitle = `Videos Recomendados | ${SITE_TITLE}`;
const pageDescription = 'Colección de videos recomendados sobre autismo, neurodivergencia y más.';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2em 1em;
			}
			.page-header {
				text-align: center;
				margin-bottom: 2rem;
				padding-bottom: 1rem;
				border-bottom: 2px solid rgb(var(--accent));
			}
			.page-header h1 {
				margin: 0;
				font-size: 2rem;
				color: rgb(var(--black));
			}
			.page-header p {
				margin: 0.5rem 0 0 0;
				color: rgb(var(--gray));
				font-size: 1.1rem;
			}
			.video-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			.video-card {
				background: rgba(var(--gray), 0.05);
				border-radius: 12px;
				padding: 1.5rem;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			.video-card:hover {
				transform: translateY(-4px);
				box-shadow: var(--box-shadow);
			}
			.video-card a {
				text-decoration: none;
				color: inherit;
				display: block;
			}
			.video-placeholder {
				width: 100%;
				height: 200px;
				background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
				border-radius: 8px;
				display: flex;
				align-items: center;
				justify-content: center;
				color: white;
				font-size: 3rem;
				margin-bottom: 1rem;
			}
			.video-card h2 {
				margin: 0 0 0.5rem 0;
				font-size: 1.25rem;
				color: rgb(var(--black));
				line-height: 1.3;
			}
			.video-card .date {
				color: rgb(var(--gray));
				font-size: 0.875rem;
				margin: 0;
			}
			.video-card .description {
				color: rgb(var(--gray));
				font-size: 0.9rem;
				margin-top: 0.75rem;
				line-height: 1.5;
			}
			.empty-state {
				text-align: center;
				padding: 4rem 2rem;
				color: rgb(var(--gray));
			}
			.empty-state h2 {
				margin: 0 0 1rem 0;
				font-size: 1.5rem;
			}
			.back-link {
				display: inline-block;
				margin-top: 2rem;
				padding: 0.75rem 1.5rem;
				background: rgb(var(--accent));
				color: white;
				text-decoration: none;
				border-radius: 4px;
				font-weight: 500;
				transition: background 0.2s ease;
			}
			.back-link:hover {
				background: rgb(var(--accent-dark));
			}
			@media (max-width: 720px) {
				.video-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>🎬 Videos Recomendados</h1>
				<p>Una selección de videos sobre autismo, neurodivergencia y más</p>
			</div>

			{videoPosts.length > 0 ? (
				<ul class="video-grid">
					{videoPosts.map((video) => (
						<li class="video-card">
							<a href={`/${video.id}/`}>
								<div class="video-placeholder">▶</div>
								<h2>{video.data.title}</h2>
								<p class="date">
									<FormattedDate date={video.data.pubDate} />
								</p>
								{video.data.description && (
									<p class="description">{video.data.description}</p>
								)}
							</a>
						</li>
					))}
				</ul>
			) : (
				<div class="empty-state">
					<h2>No hay videos aún</h2>
					<p>Próximamente agregaré recomendaciones de videos.</p>
				</div>
			)}

			<a href="/" class="back-link">← Volver al inicio</a>
		</main>
		<Footer />
	</body>
</html>